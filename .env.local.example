# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key: kept only for lib/db.ts, a future admin/system escape hatch.
# No user-facing route should need it — RLS + the anon key handle everything.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — comma-separated allowlist for Google sign-in (invite-only)
ALLOWED_EMAILS=you@example.com,teammate@example.com

# QuickBooks Online OAuth 2.0 — this app's own registered Intuit client,
# shared across all tenants (each still connects their own QBO company)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox

NEXT_PUBLIC_APP_URL=http://localhost:3000
