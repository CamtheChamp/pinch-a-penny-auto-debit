# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: use service role key for server-side writes (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# QuickBooks Online OAuth 2.0 (stubbed — set up after confirming transaction type)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
